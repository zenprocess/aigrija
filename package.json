{
  "name": "ai-grija-ro",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npx wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:ui",
    "build:ui": "vite build --config vite.config.ui.ts",
    "build:studio": "cd studio && npx sanity build --output-path ./dist",
    "deploy:studio": "cd studio && npx wrangler deploy",
    "deploy:studio:preview": "cd studio && npx wrangler deploy --env preview",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:stories": "npx tsx e2e/run-stories.ts",
    "test:all": "vitest run && playwright test",
    "test:bowser": "tsx e2e/bowser-dispatch.ts",
    "ext:pack": "cd extension && zip -r ../dist/ai-grija-extension.zip . -x '*.DS_Store'",
    "deploy:preview": "npx wrangler deploy --env preview",
    "db:migrate": "npx wrangler d1 execute ai-grija-admin --file=migrations/0001_admin_schema.sql --remote && npx wrangler d1 execute ai-grija-admin --file=migrations/0002_conversations_reports.sql --remote",
    "db:migrate:preview": "npx wrangler d1 execute ai-grija-admin-preview --file=migrations/0001_admin_schema.sql --remote && npx wrangler d1 execute ai-grija-admin-preview --file=migrations/0002_conversations_reports.sql --remote",
    "test:explore": "tsx e2e/bowser-explore.ts",
    "seed": "tsx scripts/seed-content.ts"
  },
  "dependencies": {
    "@dicebear/collection": "^9.3.2",
    "@dicebear/core": "^9.4.1",
    "@sentry/cloudflare": "^9.47.1",
    "chanfana": "^3.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "hono": "^4.12.7",
    "html-react-parser": "^5.2.17",
    "lucide-react": "^0.575.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "undici": ">=7.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cloudflare/workers-types": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@types/dompurify": "^3.2.0",
    "@types/js-yaml": "^4.0.9",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "allure-commandline": "^2.37.0",
    "allure-js-commons": "^3.5.0",
    "allure-playwright": "^3.5.0",
    "autoprefixer": "^10.4.27",
    "js-yaml": "^4.1.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0",
    "wrangler": "^4.73.0"
  }
}
