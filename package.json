{
  "name": "ai-grija-ro",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build:ui": "vite build --config vite.config.ui.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:stories": "npx tsx e2e/run-stories.ts",
    "test:all": "vitest run && playwright test",
    "test:bowser": "tsx e2e/bowser-dispatch.ts",
    "ext:pack": "cd extension && zip -r ../dist/ai-grija-extension.zip . -x '*.DS_Store'"
  },
  "dependencies": {
    "chanfana": "^3.2.1",
    "hono": "^4.7.0",
    "lucide-react": "^0.575.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "js-yaml": "^4.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
